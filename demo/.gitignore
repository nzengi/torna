# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# faucet + program keypairs (secrets) -- NEVER commit these
deploy/*.json
.env.local
# src/lib/market.json is intentionally tracked as a deploy-safe file: it holds the deployed program
# IDs, mints, vaults, a PUBLIC rpcUrl, and the demo identity keypairs (by-design public, the frontend
# signs with them in the browser). INVARIANT: never put a private RPC key in this file; the private
# Helius key lives only in .env.local / the host env (NEXT_PUBLIC_RPC_URL).
